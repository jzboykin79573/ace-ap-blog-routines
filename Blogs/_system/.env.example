# Copy this file to .env and fill in real values. Never commit .env.

# WordPress site (no trailing slash)
WP_URL=https://enginearu.com

# WordPress username for the user the post should be authored as.
# This is the LOGIN username, not the display name.
WP_USER=

# Application Password generated in WP Admin > Users > Zach Boykin > Application Passwords.
# Format looks like: xxxx xxxx xxxx xxxx xxxx xxxx (spaces are fine).
WP_APP_PASSWORD=

# Display name of the author. Resolved to a numeric WP user ID on first run and cached
# in .wp-author-id. Override if your display name differs from "Zach Boykin".
WP_AUTHOR_NAME=Zach Boykin

# Absolute path to the local folder where you save featured images exported from
# Claude Design. The cron wrapper matches files by post slug in the filename.
# Example: /Users/zachboykin/AIProjects/Blog Titles
BLOG_TITLES_FOLDER=

# Asana Personal Access Token. Used by asana-pull.mjs to download draft files
# attached to "ACE blog topics — *" tasks. Generate at app.asana.com/0/my-apps.
ASANA_PAT=
